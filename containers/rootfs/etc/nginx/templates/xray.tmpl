server
{
	listen 8080 reuseport default_server;
	listen [::]:8080 reuseport default_server;
	server_name _;
	root $CR_NGINX_WORK_DIR;
	index index.html index.htm;

	location /
	{
		try_files $$uri $$uri/ =404;
	}

	location $CR_XRAY_WS_PATH
	{
		if ($$http_upgrade != "websocket") {
			return 404;
		}
		proxy_pass http://unix:/run/xray/xray.sock:;
		proxy_http_version 1.1;
		proxy_set_header Upgrade $$http_upgrade;
		proxy_set_header Connection $$connection_upgrade;
		proxy_read_timeout 3600s;
		proxy_send_timeout 3600s;
		proxy_connect_timeout 15s;
		gzip off;
		proxy_redirect off;
		proxy_buffering off;
		proxy_request_buffering off;
		proxy_buffer_size 4k;
		proxy_busy_buffers_size 8k;
		proxy_set_header Host $$host;
		proxy_set_header X-Real-IP $CR_NGINX_REAL_IP;
		proxy_set_header X-Forwarded-For $CR_NGINX_REAL_IP;
		proxy_set_header X-Forwarded-Proto $$http_x_forwarded_proto;
		proxy_set_header X-Forwarded-Port $$pass_port;
		proxy_set_header Sec-WebSocket-Key $$http_sec_websocket_key;
		proxy_set_header Sec-WebSocket-Version $$http_sec_websocket_version;
		proxy_set_header Sec-WebSocket-Extensions $$http_sec_websocket_extensions;
	}
}
